# ============================================================
# monoi.cn 云上后端 .env  (放 /data/monoi-server/.env)
# 大部分真实值直接从家里 D:\monoi-server\.env 抄过来,
# 只有标 ★云上改动★ 的几项需要按云环境改。
# 切记: 此文件含密钥, 不进 git (.gitignore 已挡)。
# ============================================================

# ---------- 核心安全 ----------
# ★云上改动★ 用强随机, 别再用默认的 monoi-secret-key-2025
# (改了之后所有老 token 失效, 用户需重新登录一次, 迁移期反正要重登, 无所谓)
JWT_SECRET_KEY=xUfKnTfRQTwdLG5MIKxvy5OS/1mUhdEXIfvuwFrhnGcm2eh/JxiFXIXGAR5fwjVr

# CORS 允许的前端来源 (逗号分隔)。不配走代码默认列表 (已含 monoi.cn / vercel.app)
# 如要显式配: ALLOWED_ORIGINS=https://monoi.cn,https://www.monoi.cn,https://monoi-cn.vercel.app

# ---------- AI / 第三方 API (从家里 .env 抄) ----------
DEEPSEEK_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# MiniMax (如在用; 不用可留空)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_API_BASE=
MINIMAX_MODEL=

# ---------- 阿里云 OSS (中转桶) ----------
# ★云上改动★ endpoint 用【内网】, 同地域服务器→OSS 免流量费 + 更快
OSS_ENDPOINT=oss-cn-shenzhen-internal.aliyuncs.com
OSS_BUCKET=monoi-cn
# OSS 的 AK (oss_helper 优先读 OSS_ACCESS_KEY_*, 没有再回退 ALIYUN_AK_*)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 通用阿里云 AK (NLS/其他也用; 可与上面 OSS 的相同)
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=

# ---------- 阿里云验证码 (登录用 captcha) ----------
ALIYUN_CAPTCHA_ACCESS_KEY_ID=
ALIYUN_CAPTCHA_ACCESS_KEY_SECRET=
ALIYUN_CAPTCHA_SCENE_ID=
ALIYUN_APP_KEY=

# ---------- 阿里云短信 (手机验证码登录) ----------
# 不想立刻配短信可先 SMS_FORCE_MOCK=1 跳过 (登录走 mock, 上线前再配真值)
SMS_FORCE_MOCK=0
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
SMS_TEMPLATE_REGISTER=
SMS_IP_LIMIT_PER_HOUR=10

# ---------- 公共回调地址 ----------
# ★云上改动★ 从 monoi.nat100.top 改成正式域名
PUBLIC_BASE_URL=https://monoi.cn

# ---------- 微信支付 (从家里 .env 抄; 证书文件要单独传) ----------
# ★云上改动★ 回调 URL 改 monoi.cn
WX_NOTIFY_URL=https://monoi.cn/api/pay/wx/notify
WX_APP_ID=
WX_MCH_ID=
WX_CERT_SERIAL_NO=
WX_WECHATPAY_PUBLIC_KEY_ID=
# ↓ 这两个是【文件路径】, 对应的 .pem 文件要从家里拷到云上同一路径
WX_PRIVATE_KEY_PATH=/data/monoi-server/certs/apiclient_key.pem
WX_WECHATPAY_PUBLIC_KEY_PATH=/data/monoi-server/certs/wxpay_pub_key.pem

# ---------- 支付宝当面付 (审批通过后再填) ----------
ALIPAY_NOTIFY_URL=https://monoi.cn/api/pay/alipay/notify
ALIPAY_APP_ID=
ALIPAY_APP_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ---------- 登录防爆破 / 管理后台 (有默认值, 可不配) ----------
# LOGIN_LOCK_THRESHOLD=5
# LOGIN_LOCK_WINDOW_SEC=300
# LOGIN_LOCK_DURATION_SEC=900
# ADMIN_IP_WHITELIST=

# ---------- 跨平台路径 (main.py 已按 os.name 给 Linux 默认值, 一般不用配) ----------
# VOICE_PROMPTS_DIR / NARRATION_OUTPUT_DIR / DUIX_DATA_DIR / DUIX_AVATAR_DIR / FONTS_DIR
