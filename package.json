{
  "name": "monoi",
  "private": true,
  "version": "0.1.1",
  "description": "monoi 视频创作 — 桌面端 (Electron 壳, 内容来自 monoi.cn)",
  "author": "monoi.cn",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node dev-server.mjs",
    "dev:all": "node dev-server.mjs & npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:electron": "tsc -p electron/tsconfig.json && node electron/post-build.mjs",
    "dev:electron": "npm run build:electron && electron .",
    "dev:electron:local": "MONOI_URL=http://localhost:5173 npm run dev:electron",
    "pack:win": "npm run build:electron && electron-builder --win --config electron-builder.yml",
    "pack:mac": "npm run build:electron && electron-builder --mac --config electron-builder.yml"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "jsonrepair": "^3.14.0",
    "jszip": "^3.10.1",
    "electron-updater": "^6.3.0",
    "uiohook-napi": "^1.5.4",
    "konva": "^10.3.0",
    "lucide-react": "^1.11.0",
    "playwright-core": "^1.55.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-konva": "^19.2.4",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4",
    "wavesurfer.js": "^7.12.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.13",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
